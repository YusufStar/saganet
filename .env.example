# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saganet

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=saganet

# Redis
REDIS_URL=redis://localhost:6379

# JWT (openssl rand -hex 32)
JWT_SECRET=0f8425c440184257cf19bab2cad55519d37597defda445b248468566bd63530d
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Services
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
CATALOG_SERVICE_PORT=3002
INVENTORY_SERVICE_PORT=3003
ORDER_SERVICE_PORT=3004
PAYMENT_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006

# Observability
JAEGER_ENDPOINT=http://localhost:4318/v1/traces
LOG_LEVEL=debug

# Payment (mock for dev)
PAYMENT_PROVIDER=mock

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@saganet.com

# Service URLs (api-gateway routing)
AUTH_SERVICE_URL=http://localhost:3001
CATALOG_SERVICE_URL=http://localhost:3002
INVENTORY_SERVICE_URL=http://localhost:3003
ORDER_SERVICE_URL=http://localhost:3004
PAYMENT_SERVICE_URL=http://localhost:3005
NOTIFICATION_SERVICE_URL=http://localhost:3006

# Storage (MinIO — S3-compatible)
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_REGION=us-east-1
MINIO_BUCKET=saganet

# Security (openssl rand -hex 32)
INTERNAL_SECRET=

# App
APP_BASE_URL=http://localhost:3000

# Admin seed (auto-created on first boot if no admin exists)
ADMIN_EMAIL=admin@saganet.com
ADMIN_PASSWORD=Admin1234!
