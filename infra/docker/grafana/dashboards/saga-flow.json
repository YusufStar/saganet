{
  "title": "Saga Flow",
  "uid": "saganet-saga",
  "version": 1,
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Orders Created (rate)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "sum(rate(order_created_total[1m]))", "legendFormat": "Orders/min"}]
    },
    {
      "id": 2,
      "title": "Saga Success vs Failure",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {"expr": "sum(rate(order_completed_total[5m]))", "legendFormat": "Completed"},
        {"expr": "sum(rate(order_failed_total[5m]))", "legendFormat": "Failed"}
      ]
    },
    {
      "id": 3,
      "title": "Order Processing Duration (p95)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(order_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95"}]
    },
    {
      "id": 4,
      "title": "DLQ Messages (5m)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 16},
      "targets": [{"expr": "sum(increase(kafka_dlq_messages_total[5m]))", "legendFormat": "DLQ msgs"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 1, "color": "red"}]}}}
    }
  ],
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s"
}
