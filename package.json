{
  "name": "saganet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter \"{./apps/*}\" run --parallel --stream --workspace-concurrency=10 dev",
    "build": "pnpm --filter \"{./packages/*}\" run build && pnpm --filter \"{./apps/*}\" run build",
    "test": "pnpm --filter \"{./packages/*}\" --filter \"{./apps/*}\" run test",
    "lint": "eslint . --ext .ts",
    "typecheck": "pnpm --filter \"{./apps/*}\" run typecheck",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\"",
    "migration:run": "pnpm --filter \"{./apps/*}\" run --if-present --workspace-concurrency=1 migration:run"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@scarf/scarf",
      "bcrypt",
      "unrs-resolver",
      "sharp"
    ]
  }
}
